{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TheLab",
  "version": "0.0.1",
  "identifier": "com.the-lab-mmo-manager.ui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "THE LAB | presented by 0xV31L and Dad's MMO Lab ",
        "width": 1280,
        "height": 800,
        "center": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/invntiv/dads-mmo-lab-ui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0NTkzQTU3MjY3RDE3NjUKUldSbEYzMG1WenBaWk9MRHVnalFSUUJ4WDcrelFnb2hjTkF0b0IvUjg0dlIwcG13cFNUSVF4c00K"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "createUpdaterArtifacts": true,
    "resources": {
      "../../install-wow-ui.sh": "install-wow-ui.sh",
      "../../uninstall-wow-ui.sh": "uninstall-wow-ui.sh",
      "../../dml-bootstrap.sh": "dml-bootstrap.sh",
      "../../fix-after-update-ui.sh": "fix-after-update-ui.sh",
      "../../eluna-scripts/dml_addclass.lua": "eluna-scripts/dml_addclass.lua",
      "../../eluna-scripts/dml_gm.lua": "eluna-scripts/dml_gm.lua",
      "../../eluna-scripts/dml_login.lua": "eluna-scripts/dml_login.lua",
      "../../eluna-scripts/dml_uninvite.lua": "eluna-scripts/dml_uninvite.lua",
      "../../eluna-scripts/dml_whisper.lua": "eluna-scripts/dml_whisper.lua"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
